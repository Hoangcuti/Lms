@{
    ViewData["Title"] = "Super Admin Dashboard";
}

<div class="dashboard-container">
    <div class="header-section">
        <h1>Super Admin Dashboard</h1>
        <p>Hệ quản trị tối cao của Corporate LMS Pro</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card admin-theme">
            <div class="stat-info">
                <h3>Tổng người dùng</h3>
                <div class="value">--</div>
            </div>
            <div class="stat-icon"><i class="fas fa-users"></i></div>
        </div>
        <div class="stat-card admin-theme">
            <div class="stat-info">
                <h3>Tổng khóa học</h3>
                <div class="value">--</div>
            </div>
            <div class="stat-icon"><i class="fas fa-book"></i></div>
        </div>
        <div class="stat-card admin-theme">
            <div class="stat-info">
                <h3>Báo cáo hệ thống</h3>
                <div class="value">--</div>
            </div>
            <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
        </div>
    </div>

    <div class="admin-message">
        <div class="icon"><i class="fas fa-shield-alt"></i></div>
        <div class="content">
            <h3>Chào mừng Admin!</h3>
            <p>Đây là giao diện quản trị tổng thể. Vui lòng sử dụng thanh menu bên trái để quản lý toàn bộ hệ thống.</p>
        </div>
    </div>
</div>

<style>
    .dashboard-container { padding: 2rem; }
    .header-section { margin-bottom: 2.5rem; }
    .header-section h1 { font-size: 2.4rem; font-weight: 800; color: #1a1a1a; margin-bottom: 0.5rem; }
    .header-section p { color: #666; font-size: 1.1rem; }

    .stats-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
        gap: 1.5rem; 
        margin-bottom: 3rem; 
    }

    .stat-card {
        background: #fff;
        padding: 1.5rem 2rem;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: transform 0.3s ease;
        border-bottom: 4px solid #dc3545;
    }

    .stat-card:hover { transform: translateY(-5px); }
    .stat-info h3 { font-size: 1rem; color: #888; font-weight: 500; margin-bottom: 0.5rem; }
    .stat-info .value { font-size: 2.2rem; font-weight: 800; color: #333; }
    .stat-icon { font-size: 2.5rem; opacity: 0.2; color: #dc3545; }

    .admin-message {
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, #fff 0%, #fff5f5 100%);
        padding: 2rem;
        border-radius: 1.5rem;
        border: 1px solid #ffcccc;
    }

    .admin-message .icon {
        font-size: 3rem;
        color: #dc3545;
        margin-right: 2rem;
    }

    .admin-message h3 { font-size: 1.5rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.5rem; }
    .admin-message p { color: #555; line-height: 1.6; }
</style>
