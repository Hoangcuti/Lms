@model KhoaHoc.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="dashboard-container">
    <div class="header-section">
        <h1>Quản trị Hệ thống (Admin)</h1>
        <p>Quản lý người dùng, phân quyền và theo dõi hoạt động hệ thống.</p>
    </div>

    <!-- Báo cáo tổng (Stats Grid) -->
    <div class="stats-grid">
        <div class="stat-card admin-theme">
            <div class="stat-info">
                <h3>Tổng Số Người Học</h3>
                <div class="value">@Model.TotalLearners</div>
            </div>
            <div class="stat-icon"><i class="fas fa-users"></i></div>
        </div>
        <div class="stat-card admin-theme completion-card">
            <div class="stat-info">
                <h3>Tỷ Lệ Hoàn Thành</h3>
                <div class="completion-detail">
                    <div class="completion-legend">
                        <div class="legend-item"><span class="dot dot-done"></span> Hoàn thành: @(Model.CompletionRate)%</div>
                        <div class="legend-item"><span class="dot dot-remain"></span> Chưa hoàn thành: @(100 - Model.CompletionRate)%</div>
                    </div>
                </div>
            </div>
            <div class="donut-wrap">
                <svg class="donut-svg" viewBox="0 0 120 120">
                    <circle class="donut-bg" cx="60" cy="60" r="48" />
                    <circle class="donut-progress" id="donutProgress" cx="60" cy="60" r="48"
                            stroke-dasharray="0 301.59"
                            data-value="@Model.CompletionRate" />
                </svg>
                <div class="donut-center">
                    <span class="donut-pct" id="donutPct">0%</span>
                    <span class="donut-label">Hoàn thành</span>
                </div>
            </div>
        </div>
        <div class="stat-card admin-theme">
            <div class="stat-info">
                <h3>Điểm Trung Bình</h3>
                <div class="value">@(Model.AverageScore) / 10</div>
            </div>
            <div class="stat-icon"><i class="fas fa-star"></i></div>
        </div>
    </div>

    <!-- Tab Control cho các chức năng -->
    <div class="admin-tabs-container card">
        <div class="tabs-header">
            <button class="tab-btn active" onclick="switchTab('users-tab')">
                <i class="fas fa-users-cog"></i> Quản lý Người dùng & Phân quyền
            </button>
            <button class="tab-btn" onclick="switchTab('logs-tab')">
                <i class="fas fa-clipboard-list"></i> Nhật ký hoạt động
            </button>
        </div>

        <div class="tabs-content">
            <!-- Tab: Quản lý Người dùng -->
            <div id="users-tab" class="tab-pane active">
                <div class="toolbar">
                    <div class="toolbar-left">
                        <button class="btn btn-success" onclick="openAddModal()"><i class="fas fa-plus"></i> Thêm mới</button>
                        <button class="btn btn-primary" onclick="openEditModal()"><i class="fas fa-edit"></i> Sửa</button>
                        <button class="btn btn-danger" onclick="deleteSelected()"><i class="fas fa-trash-alt"></i> Xóa</button>
                    </div>
                    <div class="toolbar-right">
                        <button class="btn btn-warning" style="color: #fff;" onclick="resetPassword()"><i class="fas fa-key"></i> Reset Mật khẩu</button>
                        <button class="btn btn-dark" onclick="toggleStatus()"><i class="fas fa-user-lock"></i> Khóa / Mở tài khoản</button>
                        <div class="role-selector">
                            <select class="form-select" id="roleSelect">
                                <option value="">-- Đổi Role --</option>
                                @foreach(var r in Model.AvailableRoles)
                                {
                                    <option value="@r.RoleId">@r.RoleName</option>
                                }
                            </select>
                            <button class="btn btn-info" style="color: #fff;" onclick="changeRole()">Áp dụng Role</button>
                        </div>
                    </div>
                </div>

                <div class="table-wrapper">
                    <table class="lms-table" id="usersTable">
                        <thead>
                            <tr>
                                <th style="width: 40px;"></th>
                                <th>Username</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Phòng ban</th>
                                <th>Role</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var u in Model.Users)
                            {
                                if (u.Status == "Deleted") continue;
                                var roleNames = u.Roles.Select(r => r.RoleName).ToList();
                                var roleStr = roleNames.Any() ? string.Join(", ", roleNames) : "Employee";
                                
                                <tr>
                                    <td><input type="radio" name="selectedUser" value="@u.UserId" 
                                            data-fullname="@u.FullName" 
                                            data-email="@u.Email" 
                                            data-dept="@u.DepartmentId" /></td>
                                    <td><div style="font-weight:600;">@u.Username</div></td>
                                    <td>@u.FullName</td>
                                    <td>@u.Email</td>
                                    <td>@(u.Department?.DepartmentName ?? "N/A")</td>
                                    <td><span class="badge badge-blue">@roleStr</span></td>
                                    <td>
                                        @if(u.Status == "Active") {
                                            <span class="badge badge-success">Active</span>
                                        } else {
                                            <span class="badge badge-danger">Locked</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tab: Nhật ký hoạt động -->
            <div id="logs-tab" class="tab-pane">
                <div class="table-wrapper">
                    <table class="lms-table">
                        <thead>
                            <tr>
                                <th>Thời gian</th>
                                <th>Người dùng</th>
                                <th>Hành động</th>
                                <th>Bảng</th>
                                <th>Chi tiết</th>
                                <th>IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var log in Model.RecentLogs)
                            {
                                <tr>
                                    <td style="color:#64748b; font-size:13px;">@log.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td style="font-weight:600;">@(log.User?.Username ?? "System")</td>
                                    <td><span class="badge badge-warning">@log.ActionType</span></td>
                                    <td>@log.TableName</td>
                                    <td>@log.Description</td>
                                    <td>@log.Ipaddress</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Thêm / Sửa -->
<div id="userModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h3 id="modalTitle">Thêm mới Người dùng</h3>
            <span class="close-modal" onclick="closeModal()">&times;</span>
        </div>
        <div class="custom-modal-body">
            <input type="hidden" id="modalUserId" />
            
            <div class="form-group mb-3" id="groupUsername">
                <label class="form-label-styled"><i class="fas fa-user" style="color:#2563eb"></i> Username</label>
                <input type="text" id="modalUsername" class="form-control" placeholder="Nhập username..." />
            </div>
            
            <div class="form-group mb-3">
                <label class="form-label-styled"><i class="fas fa-id-card" style="color:#10b981"></i> Họ tên</label>
                <input type="text" id="modalFullName" class="form-control" placeholder="Nhập họ và tên..." />
            </div>
            
            <div class="form-group mb-3">
                <label class="form-label-styled"><i class="fas fa-envelope" style="color:#f59e0b"></i> Email</label>
                <input type="email" id="modalEmail" class="form-control" placeholder="Nhập địa chỉ email..." />
            </div>
            
            <div class="form-group mb-3">
                <label class="form-label-styled"><i class="fas fa-building" style="color:#8b5cf6"></i> Phòng ban</label>
                <select id="modalDept" class="form-select">
                    <option value="">-- Chọn phòng ban --</option>
                    @foreach(var d in Model.Departments)
                    {
                        <option value="@d.DepartmentId">@d.DepartmentName</option>
                    }
                </select>
            </div>
            
            <div class="form-group mb-3" id="groupRole">
                <label class="form-label-styled"><i class="fas fa-shield-alt" style="color:#ef4444"></i> Phân quyền (Role)</label>
                <select id="modalRole" class="form-select">
                    <option value="">Employee (Mặc định)</option>
                    @foreach(var r in Model.AvailableRoles)
                    {
                        <option value="@r.RoleName">@r.RoleName</option>
                    }
                </select>
            </div>
            
        </div>
        <div class="custom-modal-footer">
            <button class="btn btn-secondary" onclick="closeModal()">Hủy</button>
            <button class="btn btn-primary" onclick="saveUser()">Lưu</button>
        </div>
    </div>
</div>

<style>
    .dashboard-container { padding: 2rem; }
    .header-section { margin-bottom: 2.5rem; }
    .header-section h1 { font-size: 2.4rem; font-weight: 800; color: #1a1a1a; margin-bottom: 0.5rem; }
    .header-section p { color: #666; font-size: 1.1rem; }

    .stats-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
        gap: 1.5rem; 
        margin-bottom: 2rem; 
    }

    .stat-card.admin-theme {
        background: #fff;
        padding: 1.5rem 2rem;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: transform 0.3s ease;
        border-bottom: 4px solid var(--primary, #2563eb);
    }

    .stat-card.admin-theme:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(37,99,235,0.1); }
    .stat-info h3 { font-size: 1rem; color: #64748b; font-weight: 600; margin-bottom: 0.5rem; }
    .stat-info .value { font-size: 2.2rem; font-weight: 800; color: #0f172a; line-height: 1.2; }
    
    .stat-icon { 
        font-size: 2.5rem; 
        color: var(--primary, #2563eb); 
        background: rgba(37,99,235,0.1);
        width: 64px; height: 64px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 1rem;
    }

    /* Donut Chart */
    .completion-card { align-items: center; gap: 1rem; }
    .completion-detail { margin-top: 0.5rem; }
    .completion-legend { display: flex; flex-direction: column; gap: 6px; margin-top: 8px; }
    .legend-item { font-size: 13px; color: #475569; font-weight: 500; display: flex; align-items: center; gap: 6px; }
    .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
    .dot-done { background: #2563eb; }
    .dot-remain { background: #e2e8f0; }

    .donut-wrap { position: relative; width: 110px; height: 110px; flex-shrink: 0; }
    .donut-svg { width: 110px; height: 110px; transform: rotate(-90deg); }
    .donut-bg { fill: none; stroke: #e2e8f0; stroke-width: 12; }
    .donut-progress {
        fill: none; stroke: #2563eb; stroke-width: 12;
        stroke-linecap: round;
        transition: stroke-dasharray 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .donut-center {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
    }
    .donut-pct { font-size: 1.3rem; font-weight: 800; color: #2563eb; }

    /* Modal label styling */
    .form-label-styled { 
        font-size: 13px; font-weight: 600; color: #374151; 
        display: flex; align-items: center; gap: 6px; margin-bottom: 5px;
    }
    .form-label-styled i { font-size: 14px; }

    .admin-tabs-container {
        background: #fff;
        border-radius: 1.2rem;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .tabs-header {
        display: flex;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    .tab-btn {
        padding: 15px 25px;
        font-size: 1rem;
        font-weight: 600;
        color: #64748b;
        background: transparent;
        border: none;
        border-bottom: 3px solid transparent;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .tab-btn:hover { color: #2563eb; background: #f1f5f9; }
    .tab-btn.active { color: #2563eb; border-bottom-color: #2563eb; background: #fff; }
    .tabs-content { padding: 20px; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; animation: fadeIn 0.3s ease; }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .toolbar-left, .toolbar-right { display: flex; gap: 10px; align-items: center; }

    .btn {
        padding: 8px 16px;
        border-radius: 6px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
    }

    .btn-success { background: #10b981; color: white; }
    .btn-primary { background: #2563eb; color: white; }
    .btn-danger { background: #ef4444; color: white; }
    .btn-warning { background: #f59e0b; color: white; }
    .btn-dark { background: #334155; color: white; }
    .btn-info { background: #06b6d4; color: white; }
    .btn-secondary { background: #e2e8f0; color: #334155; }

    .role-selector {
        display: flex;
        gap: 5px;
        border-left: 2px solid #e2e8f0;
        padding-left: 15px;
        margin-left: 5px;
    }

    .form-select {
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid #cbd5e1;
        outline: none;
        font-size: 14px;
        width: 100%;
    }

    .form-control {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
    }
    
    .mb-3 { margin-bottom: 1rem; }

    .table-wrapper {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .lms-table { width: 100%; border-collapse: collapse; }
    .lms-table th, .lms-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid #e2e8f0; }
    .lms-table th { background: #f8fafc; font-weight: 600; color: #475569; font-size: 13px; text-transform: uppercase; }
    .lms-table tbody tr:hover { background: #f1f5f9; }

    .badge { padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-success { background: #dcfce7; color: #166534; }
    .badge-danger { background: #fee2e2; color: #991b1b; }
    .badge-blue { background: #dbeafe; color: #1e40af; }
    .badge-warning { background: #fef3c7; color: #92400e; }

    /* Custom Modal */
    .custom-modal {
        display: none; 
        position: fixed; z-index: 9999; left: 0; top: 0;
        width: 100%; height: 100%; overflow: auto;
        background-color: rgba(0,0,0,0.5);
        align-items: center; justify-content: center;
    }
    .custom-modal-content {
        background-color: #fff;
        margin: auto; padding: 0;
        border-radius: 12px;
        width: 400px; max-width: 90%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .custom-modal-header {
        padding: 15px 20px;
        border-bottom: 1px solid #e2e8f0;
        display: flex; justify-content: space-between; align-items: center;
    }
    .custom-modal-header h3 { margin: 0; font-size: 1.2rem; }
    .close-modal { font-size: 1.5rem; font-weight: bold; cursor: pointer; color: #94a3b8; }
    .close-modal:hover { color: #0f172a; }
    .custom-modal-body { padding: 20px; }
    .custom-modal-footer {
        padding: 15px 20px; border-top: 1px solid #e2e8f0;
        display: flex; justify-content: flex-end; gap: 10px;
    }
</style>

<script>
    function switchTab(tabId) {
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
        event.currentTarget.classList.add('active');
        document.getElementById(tabId).classList.add('active');
    }

    function getSelectedUserId() {
        const selected = document.querySelector('input[name="selectedUser"]:checked');
        return selected ? selected.value : null;
    }

    function openAddModal() {
        document.getElementById('modalTitle').innerText = "Thêm mới Người dùng";
        document.getElementById('modalUserId').value = "";
        document.getElementById('modalUsername').value = "";
        document.getElementById('modalFullName').value = "";
        document.getElementById('modalEmail').value = "";
        document.getElementById('modalDept').value = "";
        document.getElementById('modalRole').value = "";
        
        document.getElementById('groupUsername').style.display = 'block';
        document.getElementById('groupRole').style.display = 'block';
        
        document.getElementById('userModal').style.display = 'flex';
    }

    function openEditModal() {
        const selected = document.querySelector('input[name="selectedUser"]:checked');
        if (!selected) return alert('Vui lòng chọn 1 người dùng để sửa!');

        document.getElementById('modalTitle').innerText = "Cập nhật Người dùng";
        document.getElementById('modalUserId').value = selected.value;
        document.getElementById('modalFullName').value = selected.dataset.fullname || "";
        document.getElementById('modalEmail').value = selected.dataset.email || "";
        document.getElementById('modalDept').value = selected.dataset.dept || "";
        
        document.getElementById('groupUsername').style.display = 'none';
        document.getElementById('groupRole').style.display = 'none';

        document.getElementById('userModal').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('userModal').style.display = 'none';
        document.getElementById('modalUserId').value = '';
        document.getElementById('modalUsername').value = '';
        document.getElementById('modalFullName').value = '';
        document.getElementById('modalEmail').value = '';
        document.getElementById('modalDept').value = '';
        document.getElementById('modalRole').value = '';
    }

    // Close modal when clicking outside of it
    window.onclick = function(event) {
        const modal = document.getElementById('userModal');
        if (event.target == modal) {
            closeModal();
        }
    }

    function saveUser() {
        const id = document.getElementById('modalUserId').value;
        const username = document.getElementById('modalUsername').value;
        const fullName = document.getElementById('modalFullName').value;
        const email = document.getElementById('modalEmail').value;
        const dept = document.getElementById('modalDept').value;
        const role = document.getElementById('modalRole').value;

        const isAdd = (id === "");
        const url = isAdd ? '/Admin/AddUser' : '/Admin/EditUser';
        
        const formData = new FormData();
        if(!isAdd) formData.append('userId', id);
        if(isAdd) formData.append('username', username);
        if(isAdd) formData.append('roleName', role);
        formData.append('fullName', fullName);
        formData.append('email', email);
        formData.append('departmentId', dept);

        fetch(url, { method: 'POST', body: formData })
        .then(res => res.json())
        .then(data => {
            if(data.success) {
                location.reload();
            } else {
                alert('Lỗi: ' + data.message);
            }
        });
    }

    function deleteSelected() {
        const id = getSelectedUserId();
        if(!id) return alert('Vui lòng chọn 1 người dùng!');
        if(confirm('Bạn có chắc muốn xóa người dùng này?')) {
            const formData = new FormData(); formData.append('userId', id);
            fetch('/Admin/DeleteUser', { method: 'POST', body: formData })
            .then(res => res.json()).then(data => { if(data.success) location.reload(); });
        }
    }

    function resetPassword() {
        const id = getSelectedUserId();
        if(!id) return alert('Vui lòng chọn 1 người dùng!');
        if(confirm('Mật khẩu sẽ được reset thành 123456aA@@. Tiếp tục?')) {
            const formData = new FormData(); formData.append('userId', id);
            fetch('/Admin/ResetPassword', { method: 'POST', body: formData })
            .then(res => res.json()).then(data => { if(data.success) { alert('Reset thành công!'); location.reload(); } });
        }
    }

    function toggleStatus() {
        const id = getSelectedUserId();
        if(!id) return alert('Vui lòng chọn 1 người dùng!');
        const formData = new FormData(); formData.append('userId', id);
        fetch('/Admin/ToggleStatus', { method: 'POST', body: formData })
        .then(res => res.json()).then(data => { if(data.success) location.reload(); });
    }

    function changeRole() {
        const id = getSelectedUserId();
        if(!id) return alert('Vui lòng chọn 1 người dùng!');
        const roleId = document.getElementById('roleSelect').value;
        if(!roleId) return alert('Vui lòng chọn role mới!');

        const formData = new FormData(); 
        formData.append('userId', id);
        formData.append('roleId', roleId);
        fetch('/Admin/ChangeRole', { method: 'POST', body: formData })
        .then(res => res.json()).then(data => { if(data.success) location.reload(); });
    }

    // Animate donut chart on page load
    document.addEventListener('DOMContentLoaded', function() {
        const circle = document.getElementById('donutProgress');
        const pctLabel = document.getElementById('donutPct');
        if (!circle) return;

        const value = parseFloat(circle.dataset.value) || 0;
        const circumference = 2 * Math.PI * 48; // r=48 → ~301.59
        const filled = (value / 100) * circumference;

        // Animate count-up
        let current = 0;
        const duration = 1200;
        const step = 16;
        const increment = value / (duration / step);

        const timer = setInterval(() => {
            current += increment;
            if (current >= value) { current = value; clearInterval(timer); }
            const f = (current / 100) * circumference;
            circle.setAttribute('stroke-dasharray', `${f.toFixed(2)} ${(circumference - f).toFixed(2)}`);
            pctLabel.textContent = Math.round(current) + '%';
        }, step);
    });
</script>
