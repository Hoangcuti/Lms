@{
    ViewData["Title"] = "Quản lý Phòng ban";
    Layout = "_Layout";
}

@section Header {
    <meta name="description" content="Giao diện quản lý phòng ban - nhân viên, khóa học và đào tạo nội bộ" />
    <style>
        /* ===== ENTERPRISE MANAGER DASHBOARD STYLES ===== */
        .mgr-kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
        .mgr-kpi { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; position: relative; overflow: hidden; transition: transform .2s, box-shadow .2s; }
        .mgr-kpi:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
        .mgr-kpi-accent { position: absolute; top: 0; left: 0; width: 4px; height: 100%; border-radius: 12px 0 0 12px; }
        .mgr-kpi-icon { font-size: 28px; margin-bottom: 8px; }
        .mgr-kpi-value { font-size: 28px; font-weight: 800; line-height: 1; margin-bottom: 4px; }
        .mgr-kpi-label { font-size: 14px; color: var(--text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: .5px; }
        .mgr-kpi-change { font-size: 13px; margin-top: 6px; }

        /* Employee Cards Grid */
        .emp-search-bar { display: flex; gap: 10px; margin-bottom: 20px; align-items: center; flex-wrap: wrap; }
        .emp-search-input { flex: 1; min-width: 200px; background: var(--input-bg); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; padding: 12px 16px; font-size: 16px; outline: none; transition: border-color .2s; }
        .emp-search-input:focus { border-color: var(--primary); }
        .emp-filter-btn { padding: 10px 16px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-primary); font-size: 15px; cursor: pointer; transition: all .2s; }
        .emp-filter-btn.active, .emp-filter-btn:hover { background: var(--primary); border-color: var(--primary); color: #fff; }

        .emp-cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
        .emp-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; cursor: pointer; transition: all .2s; position: relative; }
        .emp-card:hover { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,.1); transform: translateY(-1px); }
        .emp-card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
        .emp-avatar { width: 56px; height: 56px; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; flex-shrink: 0; }
        .emp-card-name { font-weight: 600; font-size: 17px; line-height: 1.2; }
        .emp-card-sub { font-size: 14px; color: var(--text-secondary); margin-top: 2px; }
        .emp-card-badge { position: absolute; top: 14px; right: 14px; }
        .emp-progress-wrap { margin-bottom: 12px; }
        .emp-progress-label { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px; }
        .emp-progress-bar { height: 6px; background: var(--border-color); border-radius: 3px; overflow: hidden; }
        .emp-progress-fill { height: 100%; border-radius: 3px; transition: width 1s ease; }
        .emp-card-actions { display: flex; gap: 8px; margin-top: 14px; }
        .emp-card-actions .btn { flex: 1; font-size: 12px; padding: 7px; justify-content: center; }

        /* Status badges */
        .badge-status-active { background: rgba(16,185,129,.15); color: #10b981; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 600; }
        .badge-status-inactive { background: rgba(148,163,184,.15); color: #94a3b8; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 600; }

        /* Course cards */
        .course-list-item { display: flex; align-items: center; gap: 14px; padding: 14px; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; margin-bottom: 10px; transition: border-color .2s; }
        .course-list-item:hover { border-color: var(--primary); }
        .course-icon-box { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .course-list-info { flex: 1; }
        .course-list-title { font-weight: 600; font-size: 14px; }
        .course-list-meta { font-size: 12px; color: var(--text-secondary); margin-top: 3px; }

        /* Assignment timeline */
        .assign-item { display: flex; gap: 14px; padding: 14px 0; border-bottom: 1px solid var(--border-color); }
        .assign-item:last-child { border-bottom: none; }
        .assign-avatar-sm { width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; color: #fff; }
        .assign-info { flex: 1; }
        .assign-name { font-weight: 600; font-size: 13px; }
        .assign-course { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
        .priority-high { background: rgba(239,68,68,.15); color: #ef4444; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 600; }
        .priority-normal { background: rgba(59,130,246,.15); color: #3b82f6; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 600; }
        .priority-low { background: rgba(16,185,129,.15); color: #10b981; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 600; }

        /* Profile Panel */
        #profileOverlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); backdrop-filter: blur(3px); z-index: 300; display: none; }
        #profilePanel { position: fixed; top: 0; right: -500px; width: 480px; height: 100vh; background: var(--bg-secondary); border-left: 1px solid var(--border-color); box-shadow: -20px 0 60px rgba(0,0,0,.5); z-index: 301; transition: right .35s cubic-bezier(.4,0,.2,1); display: flex; flex-direction: column; overflow-y: auto; }
        .profile-hero { background: linear-gradient(135deg, #1e1b4b 0%, #172554 100%); padding: 30px 24px 20px; border-bottom: 1px solid var(--border-color); }
        .profile-avatar-lg { width: 72px; height: 72px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: 700; color: #fff; margin-bottom: 14px; border: 3px solid rgba(255,255,255,.2); }
        .profile-name-lg { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
        .profile-meta { font-size: 13px; color: #94a3b8; }
        .profile-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
        .profile-tag { background: rgba(255,255,255,.1); color: #e2e8f0; border-radius: 20px; padding: 4px 12px; font-size: 11px; font-weight: 500; }
        .profile-body { padding: 20px 24px; flex: 1; }
        .profile-section { margin-bottom: 24px; }
        .profile-section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
        .course-row { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; margin-bottom: 8px; }
        .skill-bar-row { margin-bottom: 10px; }
        .skill-bar-label { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 5px; }
        .skill-bar-bg { height: 8px; background: var(--border-color); border-radius: 4px; overflow: hidden; }
        .skill-bar-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #3b82f6, #8b5cf6); }

        /* Quick stats strip in profile */
        .profile-stats-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 20px; }
        .profile-stat-box { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; text-align: center; }
        .profile-stat-num { font-size: 20px; font-weight: 700; }
        .profile-stat-lbl { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }

        /* Charts section */
        .charts-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
        @@media (max-width: 900px) { .charts-2col { grid-template-columns: 1fr; } .mgr-kpi-grid { grid-template-columns: repeat(2, 1fr); } .emp-cards-grid { grid-template-columns: 1fr; } }
    </style>
}

<div class="page-header">
    <div>
        <div class="page-title" id="pageTitle">Tổng quan bộ phận</div>
        <div class="page-subtitle" id="pageSubtitle">Dashboard quản lý nhân sự và đào tạo</div>
    </div>
    <div class="header-actions">
        <button class="btn btn-secondary" id="btnBroadcast" onclick="navigate('courses'); openAssignDeptModal();">
            📢 Giao toàn phòng
        </button>
        <button class="btn btn-primary" onclick="openModal('createEmployeeModal')">
            ➕ Thêm nhân sự
        </button>
    </div>
</div>

<div class="content-area">

    <!-- ======= PAGE: OVERVIEW ======= -->
    <div id="hr-overview" class="page-section fade-in">
        <!-- KPI Cards -->
        <div class="mgr-kpi-grid" id="kpiGrid">
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#3b82f6"></div><div class="mgr-kpi-icon">👥</div><div class="mgr-kpi-value" id="kpiEmp">—</div><div class="mgr-kpi-label">Nhân sự hiện có</div></div>
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#10b981"></div><div class="mgr-kpi-icon">✅</div><div class="mgr-kpi-value" id="kpiCompleted">—</div><div class="mgr-kpi-label">Khóa đã hoàn thành</div></div>
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#f59e0b"></div><div class="mgr-kpi-icon">📋</div><div class="mgr-kpi-value" id="kpiAssigned">—</div><div class="mgr-kpi-label">Nhiệm vụ đang giao</div></div>
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#8b5cf6"></div><div class="mgr-kpi-icon">🏅</div><div class="mgr-kpi-value" id="kpiCerts">—</div><div class="mgr-kpi-label">Chứng chỉ đạt được</div></div>
        </div>

        <!-- Charts -->
        <div class="charts-2col">
            <div class="card">
                <div class="card-header"><div class="card-title">📊 Tiến độ đào tạo theo trạng thái</div></div>
                <div class="card-body"><canvas id="progressChart" height="180"></canvas></div>
            </div>
            <div class="card">
                <div class="card-header"><div class="card-title">💰 Ngân sách đào tạo</div></div>
                <div class="card-body" style="display:flex;align-items:center;justify-content:center;gap:24px;">
                    <canvas id="budgetChart" style="max-width:160px;"></canvas>
                    <div id="budgetLegend" style="font-size:13px;"></div>
                </div>
            </div>
        </div>

        <!-- Top employees at-risk (not started) -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">⚠️ Nhân viên chưa bắt đầu đào tạo</div>
                <button class="btn btn-sm btn-secondary" onclick="navigate('members')">Xem tất cả →</button>
            </div>
            <div id="atRiskList" class="card-body" style="padding:10px 16px;">
                <div class="loading-overlay"><div class="spinner"></div></div>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: MEMBERS ======= -->
    <div id="members" class="page-section" style="display:none">
        <div class="emp-search-bar">
            <input class="emp-search-input" id="empSearch" type="text" placeholder="🔍  Tìm theo tên, mã NV, email..." oninput="filterEmployees()">
            <button class="emp-filter-btn active" id="fAll" onclick="setFilter('all')">Tất cả</button>
            <button class="emp-filter-btn" id="fActive" onclick="setFilter('active')">✅ Đang làm</button>
            <button class="emp-filter-btn" id="fInactive" onclick="setFilter('inactive')">⛔ Vô hiệu</button>
            <button class="btn btn-primary btn-sm" onclick="openModal('createEmployeeModal')">➕ Thêm nhân sự</button>
        </div>
        <div id="empCountLabel" style="font-size:13px; color:var(--text-secondary); margin-bottom:12px;"></div>
        <div class="emp-cards-grid" id="empCardsGrid">
            <div style="grid-column:1/-1; text-align:center; padding:40px;"><div class="spinner"></div></div>
        </div>
    </div>

    <!-- ======= PAGE: COURSES ======= -->
    <div id="courses" class="page-section" style="display:none">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <div style="font-size:14px; color:var(--text-secondary);" id="courseCountLabel">Đang tải...</div>
            <div style="display:flex;gap:10px;">
                <button class="btn btn-secondary" onclick="openAssignDeptModal()">📢 Giao toàn phòng</button>
                <button class="btn btn-primary" onclick="openCreateCourseModal()">✨ Tạo khóa học AI</button>
            </div>
        </div>
        <div id="courseListContainer">
            <div class="loading-overlay"><div class="spinner"></div></div>
        </div>
    </div>

    <!-- ======= PAGE: ASSIGNMENTS ======= -->
    <div id="assignments" class="page-section" style="display:none">
        <div class="card">
            <div class="card-header">
                <div class="card-title">🎯 Lịch sử phân công đào tạo</div>
                <button class="btn btn-sm btn-primary" onclick="openAssignModal()">➕ Tạo phân công</button>
            </div>
            <div class="card-body" style="padding: 0 4px;" id="assignmentListContainer">
                <div class="loading-overlay"><div class="spinner"></div></div>
            </div>
        </div>
    </div>

</div>

<!-- ========== MODALS ========== -->

<!-- Modal: Tạo khóa học (AI) -->
<div class="modal-backdrop" id="createCourseModal">
    <div class="modal-box" style="max-width:520px;">
        <div class="modal-header"><div class="modal-title">📚 Tạo khóa học nội bộ</div><button class="modal-close" onclick="closeModal('createCourseModal')">✕</button></div>
        <div class="modal-body">
            <div style="margin-bottom:20px;padding:16px;background:rgba(139,92,246,.08);border:1px dashed rgba(139,92,246,.5);border-radius:10px;">
                <div style="font-weight:700;color:#a78bfa;margin-bottom:8px;font-size:14px;">✨ Sinh nội dung bằng AI Gemini</div>
                <div style="display:flex;gap:8px;">
                    <input type="text" id="aiPrompt" class="form-input" placeholder="VD: Kỹ năng Telesale, Leadership...">
                    <button class="btn btn-primary" style="background:linear-gradient(135deg,#8b5cf6,#6366f1);white-space:nowrap;" onclick="generateWithAI()" id="btnGenerateAI">⚡ Tạo</button>
                </div>
            </div>
            <div class="form-group"><label class="form-label">Tên khóa học *</label><input type="text" id="newCourseTitle" class="form-input" placeholder="Nhập tên khóa học..."></div>
            <div class="form-group"><label class="form-label">Mô tả ngắn</label><textarea id="newCourseDescription" class="form-input" rows="4" placeholder="Mô tả nội dung và mục tiêu..."></textarea></div>
            <div class="form-group"><label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="checkbox" id="newCourseMandatory"> <span>Đây là khóa học bắt buộc</span></label></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('createCourseModal')">Hủy</button>
            <button class="btn btn-secondary" onclick="submitCreateFullCourseAI()">🤖 Tạo đầy đủ bằng AI</button>
            <button class="btn btn-primary" onclick="submitCreateCourse()">✅ Lưu khóa học</button>
        </div>
    </div>
</div>

<!-- Modal: Thêm nhân sự mới -->
<div class="modal-backdrop" id="createEmployeeModal">
    <div class="modal-box" style="max-width:460px;">
        <div class="modal-header"><div class="modal-title">➕ Thêm nhân sự mới</div><button class="modal-close" onclick="closeModal('createEmployeeModal')">✕</button></div>
        <div class="modal-body">
            <div class="form-group"><label class="form-label">Họ và Tên đầy đủ *</label><input type="text" id="newEmpName" class="form-input" placeholder="Nguyễn Văn A"></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="form-group"><label class="form-label">Mã Nhân Viên *</label><input type="text" id="newEmpCode" class="form-input" placeholder="NV001"></div>
                <div class="form-group"><label class="form-label">Email (đăng nhập) *</label><input type="email" id="newEmpEmail" class="form-input" placeholder="ten@company.com"></div>
            </div>
            <div style="margin-top:10px;padding:10px 14px;background:rgba(16,185,129,.08);border-radius:8px;font-size:12px;color:#10b981;">
                🔒 Mật khẩu mặc định: <strong>123456</strong> — Nhân viên nên đổi khi đăng nhập lần đầu.
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('createEmployeeModal')">Hủy</button>
            <button class="btn btn-primary" onclick="submitCreateEmployee()">✅ Thêm nhân sự</button>
        </div>
    </div>
</div>

<!-- Modal: Giao khóa học cá nhân -->
<div class="modal-backdrop" id="assignModal">
    <div class="modal-box" style="max-width:460px;">
        <div class="modal-header"><div class="modal-title">🎯 Phân công đào tạo</div><button class="modal-close" onclick="closeModal('assignModal')">✕</button></div>
        <div class="modal-body">
            <div class="form-group"><label class="form-label">Nhân viên *</label><select id="assignEmployee" class="form-input"><option value="">-- Chọn nhân viên --</option></select></div>
            <div class="form-group"><label class="form-label">Khóa học *</label><select id="assignCourse" class="form-input"><option value="">-- Chọn khóa học --</option></select></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="form-group"><label class="form-label">Mức ưu tiên</label>
                    <select id="assignPriority" class="form-input">
                        <option value="Normal">Bình thường</option>
                        <option value="High">Cao</option>
                        <option value="Low">Thấp</option>
                    </select>
                </div>
                <div class="form-group"><label class="form-label">Hạn hoàn thành</label><input type="date" id="assignDueDate" class="form-input"></div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('assignModal')">Hủy</button>
            <button class="btn btn-primary" onclick="submitAssignment()">🚀 Giao ngay</button>
        </div>
    </div>
</div>

<!-- Modal: Giao toàn phòng ban -->
<div class="modal-backdrop" id="assignDeptModal">
    <div class="modal-box" style="max-width:460px;">
        <div class="modal-header"><div class="modal-title">📢 Giao đào tạo toàn phòng</div><button class="modal-close" onclick="closeModal('assignDeptModal')">✕</button></div>
        <div class="modal-body">
            <div style="padding:12px;background:rgba(245,158,11,.08);border-radius:8px;font-size:13px;color:#f59e0b;margin-bottom:14px;">
                ⚡ Tất cả nhân viên đang hoạt động trong phòng ban sẽ được tự động giao khóa học này.
            </div>
            <div class="form-group"><label class="form-label">Chọn khóa học *</label><select id="assignDeptCourse" class="form-input"><option value="">-- Chọn khóa học --</option></select></div>
            <div class="form-group"><label class="form-label">Hạn hoàn thành</label><input type="date" id="assignDeptDueDate" class="form-input"></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('assignDeptModal')">Hủy</button>
            <button class="btn btn-primary" style="background:linear-gradient(135deg,#f59e0b,#d97706);" onclick="submitAssignDept()">💥 Giao toàn phòng</button>
        </div>
    </div>
</div>

<div class="modal-backdrop" id="courseContentModal">
    <div class="modal-box" style="max-width:920px; height:85vh; display:flex; flex-direction:column;">
        <div class="modal-header"><div class="modal-title" id="courseContentTitle">Quản lý nội dung khóa học</div><button class="modal-close" onclick="closeModal('courseContentModal')">✕</button></div>
        <div class="modal-body" style="flex:1; overflow:auto; background:#f8fafc;">
            <input type="hidden" id="hrContentCourseId">
            <div style="display:grid;grid-template-columns:280px 1fr;gap:16px;height:100%;">
                <div style="background:#fff;border:1px solid var(--border-color);border-radius:12px;padding:16px;">
                    <button class="btn btn-primary" style="width:100%;margin-bottom:10px" onclick="openHrModuleModal()">➕ Thêm chương</button>
                    <button class="btn btn-secondary" style="width:100%" onclick="toggleHrPublish()">📢 Publish / Draft</button>
                    <div style="margin-top:16px;font-size:12px;color:var(--text-secondary);font-weight:700;">CHƯƠNG HỌC</div>
                    <div id="hrModuleList" style="margin-top:10px;display:flex;flex-direction:column;gap:8px;"></div>
                    <div style="margin-top:16px;font-size:12px;color:var(--text-secondary);font-weight:700;">BÀI KIỂM TRA</div>
                    <div id="hrExamList" style="margin-top:10px;display:flex;flex-direction:column;gap:8px;"></div>
                </div>
                <div id="hrContentArea" style="background:#fff;border:1px solid var(--border-color);border-radius:12px;padding:20px;">
                    <div style="text-align:center;color:var(--text-secondary);padding:40px 0;">Chọn một chương để thêm bài học hoặc kiểm tra trạng thái publish.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal-backdrop" id="hrModuleModal">
    <div class="modal-box" style="max-width:460px;">
        <div class="modal-header"><div class="modal-title">➕ Thêm chương học</div><button class="modal-close" onclick="closeModal('hrModuleModal')">✕</button></div>
        <div class="modal-body">
            <div class="form-group"><label class="form-label">Tên chương *</label><input type="text" id="hrModuleTitle" class="form-input"></div>
        </div>
        <div class="modal-footer"><button class="btn btn-primary" onclick="submitHrModule()">Lưu</button></div>
    </div>
</div>

<div class="modal-backdrop" id="hrLessonModal">
    <div class="modal-box" style="max-width:520px;">
        <div class="modal-header"><div class="modal-title">➕ Thêm bài học</div><button class="modal-close" onclick="closeModal('hrLessonModal')">✕</button></div>
        <div class="modal-body">
            <input type="hidden" id="hrLessonModuleId">
            <div class="form-group"><label class="form-label">Tên bài học *</label><input type="text" id="hrLessonTitle" class="form-input"></div>
            <div class="form-group"><label class="form-label">Loại nội dung</label><select id="hrLessonType" class="form-input"><option value="Document">Tài liệu</option><option value="Video">Video</option></select></div>
            <div class="form-group"><label class="form-label">Nội dung text</label><textarea id="hrLessonBody" class="form-input" rows="4"></textarea></div>
            <div class="form-group"><label class="form-label">Link video</label><input type="text" id="hrLessonVideo" class="form-input" placeholder="https://youtube.com/..."></div>
        </div>
        <div class="modal-footer"><button class="btn btn-primary" onclick="submitHrLesson()">Lưu</button></div>
    </div>
</div>

<!-- ========== EMPLOYEE PROFILE SLIDE PANEL ========== -->
<div id="profileOverlay" onclick="if(event.target===this)closeProfilePanel()"></div>
<div id="profilePanel">
    <div class="profile-hero">
        <div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
            <button onclick="closeProfilePanel()" style="background:rgba(255,255,255,.1);border:none;color:#e2e8f0;border-radius:8px;padding:6px 12px;cursor:pointer;font-size:13px;">✕ Đóng</button>
        </div>
        <div style="display:flex;align-items:center;gap:16px;">
            <div class="profile-avatar-lg" id="prfAvatar" style="background:linear-gradient(135deg,#3b82f6,#8b5cf6);">A</div>
            <div>
                <div class="profile-name-lg" id="prfName">Đang tải...</div>
                <div class="profile-meta" id="prfMeta">...</div>
                <div style="font-size:12px;color:#64748b;margin-top:3px;" id="prfEmail">...</div>
            </div>
        </div>
        <div class="profile-tags" id="prfTags"></div>
    </div>

    <div class="profile-body">
        <div id="profileLoading" style="text-align:center;padding:40px 0;"><div class="spinner"></div><div style="margin-top:12px;color:var(--text-secondary);font-size:13px;">Đang tải hồ sơ...</div></div>
        <div id="profileContentBody" style="display:none;">
            <!-- Quick Stats -->
            <div class="profile-stats-strip" id="prfStatStrip"></div>

            <!-- Action Buttons -->
            <div style="display:flex;gap:10px;margin-bottom:20px;">
                <button class="btn btn-primary" style="flex:1;" onclick="openAssignFromProfile()">🎯 Giao khóa học</button>
                <button class="btn btn-secondary" id="prfToggleStatusBtn">⛔ Vô hiệu hóa</button>
            </div>

            <!-- Learning Progress -->
            <div class="profile-section">
                <div class="profile-section-title">📚 Lộ trình học tập</div>
                <div id="prfCourses"></div>
            </div>

            <!-- Skills -->
            <div class="profile-section">
                <div class="profile-section-title">🌟 Khung năng lực</div>
                <div id="prfSkills"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let employees = [], courses = [], charts = {}, currentFilter = 'all', currentProfileId = null, hrCourseContent = null, hrSelectedModuleId = null;
const AVATAR_COLORS = ['#3b82f6','#8b5cf6','#10b981','#f59e0b','#ef4444','#06b6d4','#ec4899'];

function avatarColor(name) { let h = 0; for(let c of name) h += c.charCodeAt(0); return AVATAR_COLORS[h % AVATAR_COLORS.length]; }

async function init() {
    await Promise.all([loadOverview(), loadEmployeesData(), loadCourses(), loadAssignmentsData()]);
    navigate('hr-overview');
}

async function loadOverview() {
    try {
        const s = await apiFetch('/api/hr/stats');
        document.getElementById('kpiEmp').textContent = s.totalEmployees;
        document.getElementById('kpiCompleted').textContent = s.completedTrainings;
        document.getElementById('kpiAssigned').textContent = s.totalAssignments;
        document.getElementById('kpiCerts').textContent = s.totalCertificates;
        renderCharts(s);
    } catch(e) {}
}

function renderCharts(s) {
    const pCtx = document.getElementById('progressChart').getContext('2d');
    if(charts.p) charts.p.destroy();
    charts.p = new Chart(pCtx, {
        type:'doughnut',
        data:{ labels:['Hoàn thành','Đang học','Chưa bắt đầu'], datasets:[{ data:[s.completedTrainings||0, Math.max(1,s.totalAssignments-s.completedTrainings), 2], backgroundColor:['#10b981','#3b82f6','#64748b'], borderWidth:0 }] },
        options:{ plugins:{ legend:{ position:'right', labels:{ color:'#94a3b8', font:{size:12} } } }, cutout:'65%' }
    });

    const bCtx = document.getElementById('budgetChart').getContext('2d');
    if(charts.b) charts.b.destroy();
    const spent = s.spentBudget || 0, total = s.totalBudget || 1;
    charts.b = new Chart(bCtx, {
        type:'doughnut',
        data:{ labels:['Đã chi','Còn lại'], datasets:[{ data:[spent, Math.max(0,total-spent)], backgroundColor:['#6366f1','#1e293b'], borderWidth:0 }] },
        options:{ plugins:{ legend:{ display:false } }, cutout:'72%' }
    });
    document.getElementById('budgetLegend').innerHTML = `
        <div style="margin-bottom:8px;"><div style="font-size:11px;color:#94a3b8;">Đã chi</div><div style="font-weight:700;color:#6366f1">${fmtMoney(spent)}</div></div>
        <div><div style="font-size:11px;color:#94a3b8;">Tổng NS</div><div style="font-weight:700;">${fmtMoney(total)}</div></div>
        <div style="margin-top:8px;"><div style="font-size:11px;color:#94a3b8;">Đã dùng</div><div style="font-weight:700;color:${s.budgetUsagePercent>80?'#ef4444':'#10b981'}">${s.budgetUsagePercent}%</div></div>`;
}
function fmtMoney(v) { if(v>=1e9) return (v/1e9).toFixed(1)+'B'; if(v>=1e6) return (v/1e6).toFixed(1)+'M'; return v.toLocaleString(); }

async function loadEmployeesData() {
    try {
        employees = await apiFetch('/api/hr/employees');
        const sel = document.getElementById('assignEmployee');
        if(sel) sel.innerHTML = '<option value="">-- Chọn nhân viên --</option>' + employees.filter(e=>e.status==='Active').map(e=>`<option value="${e.userId}">${e.fullName}</option>`).join('');
        renderEmpCards();
        renderAtRisk();
    } catch(e) {}
}

function renderAtRisk() {
    const atRisk = employees.filter(e => e.status==='Active' && e.assignedCount === 0).slice(0, 5);
    const el = document.getElementById('atRiskList');
    if(!el) return;
    if(atRisk.length === 0) { el.innerHTML = '<div style="text-align:center;color:var(--text-secondary);padding:20px;">🎉 Tất cả nhân viên đã được giao đào tạo!</div>'; return; }
    el.innerHTML = atRisk.map(e=>`
        <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-color);">
            <div style="width:36px;height:36px;border-radius:50%;background:${avatarColor(e.fullName)};color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;">${e.fullName.charAt(0)}</div>
            <div style="flex:1;"><div style="font-weight:600;font-size:14px;">${e.fullName}</div><div style="font-size:12px;color:var(--text-secondary);">${e.email}</div></div>
            <button class="btn btn-sm btn-primary" onclick="openAssignModal(null,${e.userId})">🎯 Giao việc</button>
        </div>`).join('');
}

function setFilter(f) {
    currentFilter = f;
    ['fAll','fActive','fInactive'].forEach(id=>document.getElementById(id).classList.remove('active'));
    document.getElementById(f==='all'?'fAll':f==='active'?'fActive':'fInactive').classList.add('active');
    renderEmpCards();
}

function filterEmployees() { renderEmpCards(); }

function renderEmpCards() {
    const q = (document.getElementById('empSearch')?.value||'').toLowerCase();
    let list = employees.filter(e=>{
        const matchFilter = currentFilter==='all' || (currentFilter==='active'&&e.status==='Active') || (currentFilter==='inactive'&&e.status!=='Active');
        const matchQ = !q || e.fullName.toLowerCase().includes(q) || (e.employeeCode||'').toLowerCase().includes(q) || (e.email||'').toLowerCase().includes(q);
        return matchFilter && matchQ;
    });
    const lbl = document.getElementById('empCountLabel');
    if(lbl) lbl.textContent = `Hiển thị ${list.length} / ${employees.length} nhân viên`;
    const grid = document.getElementById('empCardsGrid');
    if(!grid) return;
    if(list.length===0){ grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text-secondary);">Không tìm thấy nhân viên phù hợp</div>'; return; }
    grid.innerHTML = list.map(e=>{
        const pct = e.assignedCount>0 ? Math.round(e.completedCount/e.assignedCount*100) : 0;
        const col = avatarColor(e.fullName);
        const isActive = e.status === 'Active';
        const pctColor = pct===100?'#10b981':pct>50?'#3b82f6':'#f59e0b';
        return `<div class="emp-card" onclick="openEmployeeProfile(${e.userId})">
            <div class="emp-card-badge"><span class="${isActive?'badge-status-active':'badge-status-inactive'}">${isActive?'Đang làm':'Vô hiệu'}</span></div>
            <div class="emp-card-header">
                <div class="emp-avatar" style="background:${col};">${e.fullName.charAt(0).toUpperCase()}</div>
                <div>
                    <div class="emp-card-name">${e.fullName}</div>
                    <div class="emp-card-sub">${e.employeeCode ? e.employeeCode : ''}</div>
                    <div class="emp-card-sub" style="margin-top:2px;">${e.email||''}</div>
                </div>
            </div>
            <div class="emp-progress-wrap">
                <div class="emp-progress-label">
                    <span style="color:var(--text-secondary);">Tiến độ đào tạo</span>
                    <span style="font-weight:700;color:${pctColor};">${pct}%</span>
                </div>
                <div class="emp-progress-bar"><div class="emp-progress-fill" style="width:${pct}%;background:${pctColor};"></div></div>
                <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">${e.completedCount}/${e.assignedCount} khóa hoàn thành</div>
            </div>
            <div class="emp-card-actions" onclick="event.stopPropagation()">
                <button class="btn btn-secondary btn-sm" onclick="openEmployeeProfile(${e.userId})">👤 Hồ sơ</button>
                <button class="btn btn-primary btn-sm" onclick="openAssignModal(null,${e.userId})">🎯 Giao việc</button>
            </div>
        </div>`;
    }).join('');
}

async function loadCourses() {
    try {
        courses = await apiFetch('/api/hr/courses');
        const opts = courses.map(c=>`<option value="${c.courseId}">${c.title}</option>`).join('');
        ['assignCourse','assignDeptCourse'].forEach(id=>{ const el=document.getElementById(id); if(el) el.innerHTML='<option value="">-- Chọn khóa học --</option>'+opts; });
        const lbl = document.getElementById('courseCountLabel');
        if(lbl) lbl.textContent = `${courses.length} khóa học trong phòng`;
        const container = document.getElementById('courseListContainer');
        if(!container) return;
        if(courses.length===0){ container.innerHTML='<div style="text-align:center;padding:60px;color:var(--text-secondary);">Chưa có khóa học nào. Hãy tạo khóa học đầu tiên bằng AI!</div>'; return; }
        container.innerHTML = courses.map(c=>{
            const isOwned = c.isOwned, isMandatory = c.isMandatory;
            return `<div class="course-list-item">
                <div class="course-icon-box" style="background:${isOwned?'rgba(99,102,241,.15)':'rgba(16,185,129,.15)'};">${isOwned?'🏠':'📖'}</div>
                <div class="course-list-info">
                    <div class="course-list-title">${c.title}</div>
                    <div class="course-list-meta">
                        <span class="badge ${isOwned?'badge-info':'badge-gray'}">${isOwned?'Tự sở hữu':'Được giao'}</span>
                        ${isMandatory?'<span class="badge badge-orange" style="margin-left:6px;">Bắt buộc</span>':''}
                        <span class="badge badge-purple" style="margin-left:6px;">${c.status || 'Draft'}</span>
                        <span style="margin-left:8px">${c.moduleCount || 0} chương • ${c.lessonCount || 0} bài • ${c.examCount || 0} quiz</span>
                    </div>
                </div>
                ${isOwned ? `<button class="btn btn-sm btn-secondary" onclick="openCourseContentModal(${c.courseId})">🧩 Nội dung</button>` : ''}
                <button class="btn btn-sm btn-secondary" onclick="openAssignDeptModal(${c.courseId})">📢 Giao phòng</button>
                <button class="btn btn-sm btn-primary" onclick="openAssignModal(${c.courseId})">🎯 Giao cá nhân</button>
            </div>`;
        }).join('');
    } catch(e) {}
}

async function loadAssignmentsData() {
    try {
        const res = await apiFetch('/api/hr/assignments');
        const list = res.assignments || [];
        const container = document.getElementById('assignmentListContainer');
        if(!container) return;
        if(list.length===0){ container.innerHTML='<div style="text-align:center;padding:40px;color:var(--text-secondary);">Chưa có phân công nào.</div>'; return; }
        container.innerHTML = list.map(a=>{
            const col = avatarColor(a.employeeName||'A');
            const priorityClass = a.priority==='High'?'priority-high':a.priority==='Low'?'priority-low':'priority-normal';
            const due = a.dueDate ? new Date(a.dueDate) : null;
            const isOverdue = due && due < new Date() ? 'color:#ef4444;' : '';
            return `<div class="assign-item">
                <div class="assign-avatar-sm" style="background:${col};">${(a.employeeName||'?').charAt(0)}</div>
                <div class="assign-info">
                    <div class="assign-name">${a.employeeName} <span class="${priorityClass}" style="margin-left:6px;">${a.priority}</span></div>
                    <div class="assign-course">📚 ${a.courseName}</div>
                </div>
                <div style="text-align:right;font-size:12px;">
                    <div style="color:var(--text-secondary);">Giao bởi: ${a.assignedBy||'—'}</div>
                    <div style="${isOverdue}margin-top:3px;">${due?due.toLocaleDateString('vi-VN'):''}</div>
                </div>
            </div>`;
        }).join('');
    } catch(e) {}
}

// ===== MODALS =====
function openCreateCourseModal() { openModal('createCourseModal'); }
function openAssignDeptModal(courseId=null) {
    if(courseId) document.getElementById('assignDeptCourse').value = courseId;
    else document.getElementById('assignDeptCourse').value = '';
    openModal('assignDeptModal');
}
function openAssignModal(courseId=null, userId=null) {
    if(courseId) document.getElementById('assignCourse').value = courseId;
    if(userId) document.getElementById('assignEmployee').value = userId;
    openModal('assignModal');
}

async function submitCreateCourse() {
    const body = { title: document.getElementById('newCourseTitle').value, description: document.getElementById('newCourseDescription').value, isMandatory: document.getElementById('newCourseMandatory').checked };
    if(!body.title) return showToast('Vui lòng nhập tên khóa học','warning');
    await apiFetch('/api/hr/courses',{method:'POST',body:JSON.stringify(body)});
    showToast('Tạo khóa học thành công!','success'); closeModal('createCourseModal'); loadCourses();
}

async function submitCreateFullCourseAI() {
    const prompt = document.getElementById('aiPrompt').value || document.getElementById('newCourseTitle').value;
    if(!prompt) return showToast('Vui lòng nhập chủ đề để AI tạo khóa học đầy đủ','warning');
    try {
        const res = await apiFetch('/api/hr/ai-create-full-course',{method:'POST',body:JSON.stringify({prompt})});
        showToast(`AI đã tạo xong "${res.title}" với ${res.modulesCreated} chương`,'success');
        closeModal('createCourseModal');
        await loadCourses();
    } catch(e) {
        showToast('Lỗi tạo khóa học đầy đủ: '+e.message,'error');
    }
}

async function submitCreateEmployee() {
    const body = { fullName: document.getElementById('newEmpName').value, employeeCode: document.getElementById('newEmpCode').value, email: document.getElementById('newEmpEmail').value };
    if(!body.fullName||!body.email||!body.employeeCode) return showToast('Vui lòng điền đủ thông tin','error');
    try {
        await apiFetch('/api/hr/employees',{method:'POST',body:JSON.stringify(body)});
        showToast('Thêm nhân sự thành công!','success'); closeModal('createEmployeeModal');
        ['newEmpName','newEmpCode','newEmpEmail'].forEach(id=>document.getElementById(id).value='');
        await loadEmployeesData(); loadOverview();
    } catch(e){ showToast('Lỗi: '+e.message,'error'); }
}

async function generateWithAI() {
    const prompt = document.getElementById('aiPrompt').value;
    if(!prompt) return showToast('Vui lòng nhập chủ đề!','warning');
    const btn = document.getElementById('btnGenerateAI');
    btn.innerHTML='✨ Đang tạo...'; btn.disabled=true;
    try {
        const res = await apiFetch('/api/hr/ai-generate-course',{method:'POST',body:JSON.stringify({prompt})});
        document.getElementById('newCourseTitle').value=res.title;
        document.getElementById('newCourseDescription').value=res.description;
        showToast('AI đã tạo nội dung thành công!','success');
    } catch(e){ showToast('Lỗi AI: '+e.message,'error'); }
    finally{ btn.innerHTML='⚡ Tạo'; btn.disabled=false; }
}

async function submitAssignDept() {
    const courseId = parseInt(document.getElementById('assignDeptCourse').value);
    if(!courseId) return showToast('Vui lòng chọn khóa học','warning');
    const dueDate = document.getElementById('assignDeptDueDate').value;
    await apiFetch('/api/hr/assign-dept',{method:'POST',body:JSON.stringify({courseId,departmentId:0,dueDate:dueDate?new Date(dueDate).toISOString():null})});
    showToast('Đã giao toàn phòng thành công!','success'); closeModal('assignDeptModal'); loadOverview();
}

async function submitAssignment() {
    const userId=parseInt(document.getElementById('assignEmployee').value), courseId=parseInt(document.getElementById('assignCourse').value);
    if(!userId||!courseId) return showToast('Vui lòng chọn đầy đủ','warning');
    const dueDate=document.getElementById('assignDueDate').value, priority=document.getElementById('assignPriority').value;
    await apiFetch('/api/hr/assignments',{method:'POST',body:JSON.stringify({userId,courseId,priority,dueDate:dueDate?new Date(dueDate).toISOString():null})});
    showToast('Giao khóa học thành công!','success'); closeModal('assignModal'); loadOverview(); loadAssignmentsData();
}

async function openCourseContentModal(courseId) {
    document.getElementById('hrContentCourseId').value = courseId;
    hrSelectedModuleId = null;
    openModal('courseContentModal');
    await loadHrCourseContent();
}

async function loadHrCourseContent() {
    const courseId = document.getElementById('hrContentCourseId').value;
    if(!courseId) return;
    hrCourseContent = await apiFetch(`/api/hr/courses/${courseId}/content`);
    document.getElementById('courseContentTitle').textContent = `Nội dung: ${hrCourseContent.title} (${hrCourseContent.status || 'Draft'})`;
    document.getElementById('hrModuleList').innerHTML = (hrCourseContent.modules || []).map(m => `
        <button class="btn btn-secondary btn-sm" style="justify-content:flex-start" onclick="selectHrModule(${m.moduleId})">${m.title} (${(m.lessons||[]).length} bài)</button>
    `).join('') || '<div style="font-size:12px;color:var(--text-secondary)">Chưa có chương nào</div>';
    document.getElementById('hrExamList').innerHTML = (hrCourseContent.exams || []).map(e => `
        <div style="padding:10px;border:1px solid var(--border-color);border-radius:8px;font-size:12px">${e.examTitle} • ${e.durationMinutes || 30} phút</div>
    `).join('') || '<div style="font-size:12px;color:var(--text-secondary)">Chưa có quiz nào</div>';
    document.getElementById('hrContentArea').innerHTML = '<div style="text-align:center;color:var(--text-secondary);padding:40px 0;">Chọn một chương để thêm bài học hoặc publish khóa học.</div>';
}

function selectHrModule(moduleId) {
    hrSelectedModuleId = moduleId;
    const module = (hrCourseContent?.modules || []).find(m => m.moduleId === moduleId);
    if(!module) return;
    document.getElementById('hrContentArea').innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div>
                <div style="font-size:18px;font-weight:700">${module.title}</div>
                <div style="font-size:12px;color:var(--text-secondary)">${(module.lessons||[]).length} bài học</div>
            </div>
            <button class="btn btn-primary btn-sm" onclick="openHrLessonModal(${module.moduleId})">➕ Thêm bài học</button>
        </div>
        ${(module.lessons||[]).length ? module.lessons.map(l => `
            <div style="padding:12px;border:1px solid var(--border-color);border-radius:10px;margin-bottom:10px;">
                <div style="font-weight:600">${l.title}</div>
                <div style="font-size:12px;color:var(--text-secondary);margin-top:4px">${l.contentType || 'Document'}${l.videoUrl ? ' • Có video' : ''}</div>
                <div style="font-size:12px;color:#475569;margin-top:6px">${(l.contentBody || '').substring(0,180)}${l.contentBody && l.contentBody.length > 180 ? '...' : ''}</div>
            </div>
        `).join('') : '<div style="text-align:center;color:var(--text-secondary);padding:30px 0;">Chưa có bài học nào trong chương này.</div>'}
    `;
}

function openHrModuleModal() {
    document.getElementById('hrModuleTitle').value = '';
    openModal('hrModuleModal');
}

async function submitHrModule() {
    const courseId = document.getElementById('hrContentCourseId').value;
    const title = document.getElementById('hrModuleTitle').value.trim();
    if(!title) return showToast('Vui lòng nhập tên chương','warning');
    await apiFetch(`/api/hr/courses/${courseId}/modules`, { method:'POST', body: JSON.stringify({ title, sortOrder: (hrCourseContent?.modules || []).length }) });
    closeModal('hrModuleModal');
    showToast('Đã thêm chương học','success');
    await loadHrCourseContent();
}

function openHrLessonModal(moduleId) {
    document.getElementById('hrLessonModuleId').value = moduleId;
    document.getElementById('hrLessonTitle').value = '';
    document.getElementById('hrLessonType').value = 'Document';
    document.getElementById('hrLessonBody').value = '';
    document.getElementById('hrLessonVideo').value = '';
    openModal('hrLessonModal');
}

async function submitHrLesson() {
    const moduleId = document.getElementById('hrLessonModuleId').value;
    const body = {
        title: document.getElementById('hrLessonTitle').value.trim(),
        contentType: document.getElementById('hrLessonType').value,
        contentBody: document.getElementById('hrLessonBody').value,
        videoUrl: document.getElementById('hrLessonVideo').value,
        sortOrder: ((hrCourseContent?.modules || []).find(m => String(m.moduleId) === String(moduleId))?.lessons || []).length
    };
    if(!body.title) return showToast('Vui lòng nhập tên bài học','warning');
    await apiFetch(`/api/hr/modules/${moduleId}/lessons`, { method:'POST', body: JSON.stringify(body) });
    closeModal('hrLessonModal');
    showToast('Đã thêm bài học','success');
    await loadHrCourseContent();
    selectHrModule(parseInt(moduleId));
}

async function toggleHrPublish() {
    const courseId = document.getElementById('hrContentCourseId').value;
    if(!courseId || !hrCourseContent) return;
    const shouldPublish = (hrCourseContent.status || 'Draft') !== 'Published';
    await apiFetch(`/api/hr/courses/${courseId}/publish`, { method:'POST', body: JSON.stringify({ publish: shouldPublish }) });
    showToast(shouldPublish ? 'Khóa học đã publish cho student' : 'Khóa học đã chuyển về Draft', 'success');
    await loadHrCourseContent();
    await loadCourses();
}

// ===== EMPLOYEE PROFILE PANEL =====
function openAssignFromProfile() { closeProfilePanel(); openAssignModal(null, currentProfileId); }

async function openEmployeeProfile(id) {
    currentProfileId = id;
    document.getElementById('profileOverlay').style.display='block';
    document.getElementById('profileLoading').style.display='block';
    document.getElementById('profileContentBody').style.display='none';
    document.getElementById('prfName').textContent='Đang tải...';
    setTimeout(()=>{ document.getElementById('profilePanel').style.right='0'; },10);
    try {
        const res = await apiFetch(`/api/hr/employees/${id}/profile`);
        const col = avatarColor(res.fullName);
        document.getElementById('prfAvatar').style.background=`linear-gradient(135deg,${col},${AVATAR_COLORS[(AVATAR_COLORS.indexOf(col)+2)%AVATAR_COLORS.length]})`;
        document.getElementById('prfAvatar').textContent=res.fullName.charAt(0).toUpperCase();
        document.getElementById('prfName').textContent=res.fullName;
        document.getElementById('prfMeta').textContent=`${res.jobTitle} • ${res.departmentName}`;
        document.getElementById('prfEmail').textContent=res.email;
        document.getElementById('prfTags').innerHTML=[
            `<span class="profile-tag">🆔 ${res.employeeCode}</span>`,
            `<span class="profile-tag" style="background:${res.status==='Active'?'rgba(16,185,129,.2)':'rgba(239,68,68,.2)'};color:${res.status==='Active'?'#10b981':'#ef4444'};">${res.status==='Active'?'✅ Đang làm':'⛔ Vô hiệu'}</span>`
        ].join('');

        const completed = res.courses.filter(c=>c.status==='Completed').length;
        const inProg = res.courses.filter(c=>c.status==='InProgress').length;
        document.getElementById('prfStatStrip').innerHTML=`
            <div class="profile-stat-box"><div class="profile-stat-num" style="color:#3b82f6">${res.courses.length}</div><div class="profile-stat-lbl">Khóa đã giao</div></div>
            <div class="profile-stat-box"><div class="profile-stat-num" style="color:#10b981">${completed}</div><div class="profile-stat-lbl">Hoàn thành</div></div>
            <div class="profile-stat-box"><div class="profile-stat-num" style="color:#f59e0b">${inProg}</div><div class="profile-stat-lbl">Đang học</div></div>`;

        const prfToggle = document.getElementById('prfToggleStatusBtn');
        prfToggle.textContent = res.status==='Active'?'⛔ Vô hiệu hóa':'✅ Kích hoạt';
        prfToggle.onclick = () => toggleUserStatus(id, res.status==='Active'?'Inactive':'Active');

        const cEl=document.getElementById('prfCourses');
        cEl.innerHTML=res.courses.length===0?'<div style="text-align:center;color:var(--text-secondary);padding:20px;">Chưa được giao đào tạo</div>':
            res.courses.map(c=>{
                const pct=c.progress||0, pctColor=pct===100?'#10b981':pct>50?'#3b82f6':'#f59e0b';
                const statusLabel=c.status==='Completed'?'Hoàn thành':c.status==='InProgress'?'Đang học':'Chưa bắt đầu';
                return `<div class="course-row">
                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px;">
                        <strong>${c.title}</strong>
                        <span style="color:${pctColor};font-weight:600;">${pct}%</span>
                    </div>
                    <div style="height:5px;background:var(--border-color);border-radius:3px;overflow:hidden;margin-bottom:5px;">
                        <div style="height:100%;background:${pctColor};width:${pct}%;"></div>
                    </div>
                    <div style="font-size:11px;color:var(--text-secondary);">${statusLabel}</div>
                </div>`;
            }).join('');

        const sEl=document.getElementById('prfSkills');
        sEl.innerHTML=res.skills.length===0?'<div style="text-align:center;color:var(--text-secondary);padding:20px;">Chưa có đánh giá kỹ năng</div>':
            res.skills.map(s=>`
                <div class="skill-bar-row">
                    <div class="skill-bar-label"><span>${s.skillName}</span><span style="font-weight:700;">${s.score}/100</span></div>
                    <div class="skill-bar-bg"><div class="skill-bar-fill" style="width:${s.score||0}%;"></div></div>
                </div>`).join('');

        document.getElementById('profileLoading').style.display='none';
        document.getElementById('profileContentBody').style.display='block';
    } catch(e) {
        document.getElementById('profileLoading').innerHTML=`<div style="color:#ef4444;text-align:center;">Lỗi tải hồ sơ: ${e.message}</div>`;
    }
}

function closeProfilePanel() {
    document.getElementById('profilePanel').style.right='-500px';
    setTimeout(()=>{ document.getElementById('profileOverlay').style.display='none'; currentProfileId=null; },350);
}

async function toggleUserStatus(id, newStatus) {
    if(!confirm(`Xác nhận ${newStatus==='Active'?'kích hoạt':'vô hiệu hóa'} nhân viên này?`)) return;
    await apiFetch(`/api/hr/employees/${id}/status`,{method:'PATCH',body:JSON.stringify(newStatus)});
    showToast('Cập nhật trạng thái thành công!','success');
    await loadEmployeesData(); closeProfilePanel();
}

function navigate(page) {
    document.querySelectorAll('.nav-link').forEach(link=>{
        link.classList.remove('active');
        const oc=link.getAttribute('onclick');
        if(oc&&oc.includes(`navigate('${page}')`)) link.classList.add('active');
        else if(page==='hr-overview'&&oc&&oc.includes('location.href')) link.classList.add('active');
    });
    const titles={'hr-overview':{t:'Tổng quan bộ phận',s:'Dashboard quản lý nhân sự và đào tạo'},'members':{t:'Nhân sự phòng ban',s:'Xem tiến độ & hồ sơ năng lực từng nhân viên'},'courses':{t:'Khóa học bộ phận',s:'Quản lý và phân công khóa học đào tạo'},'assignments':{t:'Phân công đào tạo',s:'Lịch sử giao nhiệm vụ học tập'}};
    if(titles[page]){ document.getElementById('pageTitle').textContent=titles[page].t; document.getElementById('pageSubtitle').textContent=titles[page].s; }
    document.querySelectorAll('.page-section').forEach(s=>s.style.display=s.id===page?'':'none');
}

document.addEventListener('DOMContentLoaded', init);
</script>
